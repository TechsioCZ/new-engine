{
  "name": "@techsio/ui-kit",
  "version": "0.3.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TechsioCZ/new-engine.git",
    "directory": "libs/ui"
  },
  "files": [
    "dist",
    "src/tokens"
  ],
  "type": "module",
  "exports": {
    "./types/zag": {
      "types": "./dist/src/types/zag.d.ts",
      "import": "./dist/types/zag.js"
    },
    "./tokens": {
      "style": "./src/tokens/tokens-only.css",
      "default": "./src/tokens/tokens-only.css"
    },
    "./tokens-with-tailwind": {
      "style": "./src/tokens/index.css",
      "default": "./src/tokens/index.css"
    },
    "./theme.css": {
      "style": "./src/tokens/theme.css",
      "default": "./src/tokens/theme.css"
    },
    "./tokens/*": {
      "style": "./src/tokens/*.css",
      "default": "./src/tokens/*.css"
    },
    "./atoms/*": {
      "types": "./dist/src/atoms/*.d.ts",
      "import": "./dist/atoms/*.js"
    },
    "./molecules/*": {
      "types": "./dist/src/molecules/*.d.ts",
      "import": "./dist/molecules/*.js"
    },
    "./organisms/*": {
      "types": "./dist/src/organisms/*.d.ts",
      "import": "./dist/organisms/*.js"
    },
    "./templates/*": {
      "types": "./dist/src/templates/*.d.ts",
      "import": "./dist/templates/*.js"
    },
    "./theme/*": {
      "types": "./dist/src/theme/*.d.ts",
      "import": "./dist/theme/*.js"
    },
    "./utils": {
      "types": "./dist/src/utils.d.ts",
      "import": "./dist/utils.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "build:storybook": "storybook build",
    "dev": "rslib build --watch",
    "storybook": "storybook dev",
    "figma:connect:parse": "figma connect parse --config figma.config.json",
    "figma:connect:publish": "figma connect publish --config figma.config.json",
    "test-storybook": "test-storybook",
    "storybook:a11y": "bash scripts/storybook-a11y.sh",
    "storybook:a11y:ci": "A11Y_FAIL_ON_REGRESSION=true bash scripts/storybook-a11y.sh",
    "storybook:a11y:update-baseline": "mise exec node@24 -- node scripts/storybook-a11y-regression.mjs --report-root a11y-report --baseline a11y-baseline.json --update-baseline",
    "test:components": "node scripts/run-component-tests.mjs",
    "test:components:update": "node scripts/run-component-tests.mjs --update-snapshots",
    "lint:tailwind": "eslint \"**/*.{js,jsx,ts,tsx}\" --config eslint.config.js",
    "lint:tailwind:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --config eslint.config.js --fix",
    "prepare": "pnpm build",
    "check:unused-tokens": "bun scripts/check-unused-tokens.js",
    "validate:tokens": "node scripts/validate-token-usage.js && node scripts/validate-token-definitions.js",
    "validate:token-usage": "bun scripts/validate-token-usage.js",
    "validate:token-definitions": "bun scripts/validate-token-definitions.js",
    "semantic-release": "semantic-release",
    "typecheck": "pnpm -w exec tsc --noEmit -p scripts/typescript/projects/libs/ui/tsconfig.json"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/mdi-light": "^1.2.2",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify/tailwind4": "^1.2.3",
    "@techsio/std": "workspace:*",
    "@zag-js/accordion": "^1.42.0",
    "@zag-js/carousel": "^1.42.0",
    "@zag-js/checkbox": "^1.42.0",
    "@zag-js/combobox": "^1.42.0",
    "@zag-js/dialog": "^1.42.0",
    "@zag-js/i18n-utils": "^1.42.0",
    "@zag-js/menu": "^1.42.0",
    "@zag-js/number-input": "^1.42.0",
    "@zag-js/pagination": "^1.42.0",
    "@zag-js/popover": "^1.42.0",
    "@zag-js/radio-group": "^1.42.0",
    "@zag-js/rating-group": "^1.42.0",
    "@zag-js/react": "^1.42.0",
    "@zag-js/select": "^1.42.0",
    "@zag-js/slider": "^1.42.0",
    "@zag-js/steps": "^1.42.0",
    "@zag-js/switch": "^1.42.0",
    "@zag-js/tabs": "^1.42.0",
    "@zag-js/toast": "^1.42.0",
    "@zag-js/tooltip": "^1.42.0",
    "@zag-js/tree-view": "^1.42.0",
    "better-themes": "^1.1.0",
    "libphonenumber-js": "^1.13.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/code-connect": "^1.4.9",
    "@iconify/json": "^2.2.500",
    "@rsbuild/core": "2.1.6",
    "@rsbuild/plugin-react": "2.1.0",
    "@rslib/core": "^0.23.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-themes": "^10.5.2",
    "@storybook/react": "^10.5.2",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.3",
    "@techsio/storybook-better-a11y": "0.1.3",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "9.39.1",
    "eslint-plugin-tailwindcss": "4.2.0",
    "glob": "^13.0.6",
    "postcss": "^8.5.19",
    "rsbuild-plugin-publint": "^1.0.0",
    "semantic-release": "^25.0.7",
    "storybook": "^10.5.2",
    "storybook-addon-rslib": "^3.3.4",
    "storybook-react-rsbuild": "^3.3.4",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vitest-axe": "0.1.0"
  },
  "peerDependencies": {
    "@types/react": ">=19.2.0",
    "@types/react-dom": ">=19.2.0",
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0"
  }
}
