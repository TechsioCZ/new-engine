{
  "extends": "./tsconfig.package.json",
  "compilerOptions": {
    "paths": {
      "@techsio/smart-suggest-client": ["./client/src/client.ts"],
      "@techsio/smart-suggest-core": ["./core/src/core.ts"],
      "@techsio/smart-suggest-datasets": ["./datasets/src/datasets.ts"],
      "@techsio/smart-suggest-indexing": ["./indexing/src/indexing.ts"],
      "@techsio/smart-suggest-integrations": ["./integrations/src/integrations.ts"],
      "@techsio/smart-suggest-react": ["./react/src/react.ts"],
      "@techsio/smart-suggest-storage": ["./storage/src/storage.ts"],
      "@techsio/smart-suggest-ui": ["./ui/src/address-suggest-field.tsx"],
      "@techsio/smart-suggest-ui/address-suggest-field": [
        "./ui/src/address-suggest-field.tsx"
      ],
      "@techsio/smart-suggest-ui/phone-validation-field": [
        "./ui/src/phone-validation-field.tsx"
      ],
      "@techsio/smart-suggest-ui/postal-validation-field": [
        "./ui/src/postal-validation-field.tsx"
