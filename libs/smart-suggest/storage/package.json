{
  "name": "@techsio/smart-suggest-storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rslib build",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "dev": "rslib build --watch",
    "test": "vitest run --config vitest.config.ts --typecheck",
    "test:runtime": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@rslib/core": "^0.18.0",
    "drizzle-kit": "0.31.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@techsio/smart-suggest-core": "workspace:^",
    "drizzle-orm": "^0.45.2"
  }
}
