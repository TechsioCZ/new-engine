{
  "name": "@techsio/smart-suggest-integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/integrations.d.ts",
      "import": "./dist/integrations.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rslib build --tsconfig tsconfig.build.json",
