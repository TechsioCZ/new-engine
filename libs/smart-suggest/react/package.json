{
  "name": "@techsio/smart-suggest-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rslib build --tsconfig tsconfig.build.json",
    "dev": "rslib build --watch",
    "test": "vitest run --config vitest.config.ts --typecheck",
    "test:runtime": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.89",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rslib/core": "^0.18.0",
    "@techsio/smart-suggest-tooling": "workspace:^",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@techsio/smart-suggest-core": "workspace:^",
    "@techsio/smart-suggest-validation": "workspace:^",
    "effect": "4.0.0-beta.89"
  }
}
