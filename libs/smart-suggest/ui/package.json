{
  "name": "@techsio/smart-suggest-ui",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/address-suggest-field.d.ts",
      "import": "./dist/address-suggest-field.js"
    },
    "./address-suggest-field": {
      "types": "./dist/src/address-suggest-field.d.ts",
      "import": "./dist/address-suggest-field.js"
    },
    "./phone-validation-field": {
      "types": "./dist/src/phone-validation-field.d.ts",
      "import": "./dist/phone-validation-field.js"
    },
    "./postal-validation-field": {
      "types": "./dist/src/postal-validation-field.d.ts",
      "import": "./dist/postal-validation-field.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rslib build --tsconfig tsconfig.build.json",
    "dev": "rslib build --watch",
    "test": "vitest run --config vitest.config.ts --typecheck",
    "test:runtime": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@techsio/smart-suggest-client": "workspace:^",
    "@techsio/smart-suggest-core": "workspace:^",
    "@techsio/smart-suggest-react": "workspace:^",
    "@techsio/smart-suggest-validation": "workspace:^"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^1.4.2",
    "@rslib/core": "^0.18.0",
    "@techsio/ui-kit": "workspace:^",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@techsio/ui-kit": ">=0.3.2",
    "react": ">=19.2.0"
  }
}
