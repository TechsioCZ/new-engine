{
  "threshold": 1,
  "reporters": ["html", "json", "console"],
  "ignore": [
    "**/local/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.medusa/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.test.{ts,tsx,js,jsx}",
    "**/*.spec.{ts,tsx,js,jsx}",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/fixtures/**",
    "**/storybook-static/**",
    "**/.netlify/**",
    "**/playwright-report/**",
    "**/*.generated.{ts,tsx,js,jsx}",
    "**/.cache/**",
    "**/payload-types.ts",
    "**/importMap.js",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock"
  ],
  "path": [
    "apps/",
    "libs/",
    "packages/",
    "scripts/",
    "tooling/",
    "rules/",
    "rule-tests/"
  ],
  "format": ["typescript", "javascript", "css"],
  "absolute": true,
  "gitignore": true,
  "output": "./reports/code-duplication",
  "minLines": 10,
  "minTokens": 100,
  "maxLines": 500,
  "maxSize": "500kb",
  "blame": false,
  "silent": false,
  "verbose": false,
  "mode": "mild",
  "formatsExts": {
    "typescript": ["ts", "tsx"],
    "javascript": ["js", "jsx", "mjs", "cjs"],
    "css": ["css", "scss"]
  }
}
