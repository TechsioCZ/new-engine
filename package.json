{
  "name": "@new-wr/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test-all": "cross-env TEST_ALL_ESHOPS=true nubx --node nx e2e e2e",
    "test": "nubx --node nx e2e e2e",
    "test:e2e:medusa-be:admin": "pnpm --dir apps/medusa-be test:e2e:admin",
    "test:e2e:medusa-be:http": "bash ./scripts/e2e/medusa-be-http.sh run",
    "test:e2e:medusa-be:http:debug": "MEDUSA_E2E_KEEP_STACK=1 bash ./scripts/e2e/medusa-be-http.sh run",
    "dev:all:nx": "nubx --node nx run-many --target=dev --projects=medusa-*",
    "start:fe-demo": "cd apps/frontend-demo && npm run start",
    "start:be": "cd apps/medusa-be && npm run start",
    "start:all:nx": "nubx --node nx run-many --target=start --projects=medusa-*",
    "build:be": "cd apps/medusa-be && npm run build",
    "build:all:nx": "nubx --node nx run-many --target=build --projects=medusa-*",
    "nx:affected": "NX_DAEMON=false nubx --node nx affected -t test build",
    "knip": "knip --treat-config-hints-as-errors",
    "knip:report": "knip --treat-config-hints-as-errors --reporter markdown",
    "knip:fix": "knip --fix",
    "knip:prod": "knip --production --treat-config-hints-as-errors",
    "jscpd": "jscpd",
    "prepare": "lefthook install",
    "typecheck": "node scripts/typescript/typecheck.mjs --compiler tsc",
    "typecheck:affected": "nx affected -t typecheck",
    "typecheck:tsgo": "node scripts/typescript/typecheck.mjs --compiler tsgo",
    "lint": "pnpm lint:oxlint && pnpm lint:medusa",
    "lint:advisory": "ultracite check .",
    "lint:fix": "ultracite fix .",
    "lint:oxlint": "oxlint . --type-aware --deny-warnings --ignore-pattern **/__admin-extensions__.js",
    "format": "oxfmt --config oxfmt.config.ts .",
    "format:check": "oxfmt --config oxfmt.config.ts --check .",
    "lint:medusa": "pnpm --filter medusa-be lint:medusa && pnpm --filter medusa-order-dashboard-plugin lint:medusa && pnpm --filter medusa-symmy-plugin lint:medusa",
    "depcruise": "depcruise apps libs apps/payload/vitest.config.mts libs/ui/playwright.config.cts --config dependency-cruiser.config.cjs",
    "ast-grep": "node ./tooling/ast-grep/run.mjs test --skip-snapshot-tests && node ./tooling/ast-grep/run.mjs scan --config sgconfig.yml",
    "danger": "node scripts/danger/run.mjs ci",
    "check:migrations": "node scripts/danger/check-migration-immutability.mjs",
    "lefthook": "lefthook run",
    "quality": "pnpm format:check && pnpm lint && pnpm depcruise && pnpm ast-grep && pnpm typecheck && pnpm knip && pnpm jscpd",
    "typecheck:tsc": "node scripts/typescript/typecheck.mjs --compiler tsc"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@medusajs/deps": "2.17.2",
    "@medusajs/eslint-plugin": "2.17.2",
    "@nubjs/nub": "0.4.13",
    "@nx/esbuild": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@opentelemetry/core": "2.4.0",
    "@playwright/test": "^1.61.1",
    "@rslib/core": "0.23.2",
    "@swc-node/register": "~1.12.0",
    "@swc/core": "~1.15.43",
    "@types/bun": "1.3.14",
    "@types/node": "24.12.4",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "client-only": "^0.0.1",
    "cross-env": "^10.1.0",
    "danger": "^13.0.10",
    "dependency-cruiser": "^18.1.0",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.7.0",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "konsistent": "1.0.0-beta.3",
    "lefthook": "^2.1.10",
    "nx": "23.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "react-doctor": "^0.7.8",
    "server-only": "^0.0.1",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4",
    "yaml": "^2.9.0",
    "zod": "4.2.0"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.8.0"
}
