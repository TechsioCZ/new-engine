# Shared runtime mode
DC_NODE_ENV=development

# Shared local email inputs. docker-compose maps these into each service's
# runtime env, unless the service-specific DC_* override is set.
DC_RESEND_API_KEY=re_xxxxxxxxxx
DC_RESEND_FROM_EMAIL=onboarding@resend.dev
DC_RESEND_WEBHOOK_SECRET=
DC_CONTACT_EMAIL=your-email@example.com

# N1 storefront container
DC_N1_MEDUSA_BACKEND_URL_INTERNAL=http://medusa-be:9000
DC_N1_NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
DC_N1_NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
DC_N1_NEXT_PUBLIC_MEILISEARCH_URL=http://localhost:7700
DC_N1_NEXT_PUBLIC_MEILISEARCH_API_KEY=MEILISEARCH_SEARCH_READONLY_KEY_FOR_FRONTEND
# Public Packeta widget/feed API key (Packeta admin → API keys → Web widget).
# Used by medusa-be pickup-point feed scripts.
DC_NEXT_PUBLIC_PACKETA_WIDGET_API_KEY=
DC_N1_NEXT_PUBLIC_SITE_URL=http://localhost:8000
DC_N1_NEXT_PUBLIC_META_PIXEL_ID=
DC_N1_NEXT_PUBLIC_GOOGLE_ADS_ID=
DC_N1_NEXT_PUBLIC_HEUREKA_API_KEY=
DC_N1_NEXT_PUBLIC_LEADHUB_TRACKING_ID=

# Medusa BE container: app runtime
DC_MEDUSA_BE_NOTIFICATION_PROVIDER=resend
DC_JWT_SECRET=supersecret
DC_COOKIE_SECRET=supersecret
DC_MEDUSA_BACKEND_URL=
DC_MEDUSA_COOKIE_SECURE=
DC_MEDUSA_COOKIE_SAME_SITE=
DC_MEDUSA_ADMIN_DISABLED_FOR_BACKEND_BUILD=0
DC_STORE_CORS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080,https://n1.medusa.localhost,http://localhost:9004,https://docs.medusajs.com"
DC_ADMIN_CORS="http://localhost:5173,https://admin.medusa.localhost,http://localhost:9000,https://docs.medusajs.com"
DC_AUTH_CORS="http://localhost:5173,https://admin.medusa.localhost,http://localhost:9000,https://docs.medusajs.com"
DC_SENTRY_DSN=
DC_SENTRY_NAME=
DC_SENTRY_TRACES_SAMPLE_RATE=0.1
# When DC_FEATURE_PPL_ENABLED=1, this is required. Generate with: openssl rand -hex 32
DC_SETTINGS_ENCRYPTION_KEY=
DC_FEATURE_PPL_ENABLED=0
DC_PPL_ENVIRONMENT=testing
DC_FEATURE_PACKETA_ENABLED=0
DC_PACKETA_ENVIRONMENT=testing
DC_FEATURE_PAYMENT_QR_ENABLED=0
DC_SUPERADMIN_EMAIL=
DC_SUPERADMIN_PASSWORD=
DC_INITIAL_PUBLISHABLE_KEY_NAME="Storefront Publishable Key"

# PayKit payment providers
DC_FEATURE_PAYKIT_ENABLED=0
DC_FEATURE_PAYKIT_GOPAY_ENABLED=0
DC_FEATURE_PAYKIT_STRIPE_ENABLED=0
DC_FEATURE_PAYKIT_COMGATE_ENABLED=0
DC_PAYKIT_DEBUG=0

# GoPay configuration
DC_GOPAY_CLIENT_ID=
DC_GOPAY_CLIENT_SECRET=
DC_GOPAY_GO_ID=
DC_GOPAY_SANDBOX=true
DC_GOPAY_WEBHOOK_URL=http://localhost:9000/hooks/payment/paykit_gopay

# Comgate configuration
DC_COMGATE_MERCHANT=
DC_COMGATE_SECRET=
DC_COMGATE_SANDBOX=true
# Comgate-only label passed as PayKit provider_metadata.paymentLabel.
DC_COMGATE_PAYMENT_LABEL=

# Stripe configuration
DC_STRIPE_API_KEY=
DC_STRIPE_WEBHOOK_SECRET=

# Optional Herbatica seed XML sources. Keep empty unless running seedHerbatica.
DC_HERBATICA_XML_PATH=
DC_HERBATICA_CATEGORIES_XML_PATH=

# Medusa BE container: app DB identity (source of truth; DATABASE_URL is generated in docker-compose)
DC_MEDUSA_APP_DB_USER=medusa_app
DC_MEDUSA_APP_DB_PASSWORD=medusa_app_change_me
DC_MEDUSA_APP_DB_NAME=medusa
# Reused for DATABASE_URL search_path and MEDUSA_DATABASE_SCHEMA/DATABASE_SCHEMA.
DC_MEDUSA_APP_DB_SCHEMA=medusa
DC_MEDUSA_APP_DB_HOST=medusa-db
DC_MEDUSA_APP_DB_PORT=5432

# Medusa BE container: external services
DC_LEGACY_DATABASE_URL=mysql://root:1234@engine-db:3306/n1shop
DC_VALKEY_PASSWORD=valkey_dev_change_me
DC_REDIS_URL="redis://:${DC_VALKEY_PASSWORD}@medusa-valkey:6379"
DC_MEILISEARCH_HOST=http://medusa-meilisearch:7700
DC_MEILISEARCH_BACKEND_API_KEY=MEILISEARCH_MASTER_KEY_FOR_DEVELOPMENT_ONLY
DC_MINIO_FILE_URL="http://medusa-minio:9004/medusa-bucket"
DC_MINIO_REGION="us-east-1"
DC_MINIO_BUCKET="medusa-bucket"
DC_MINIO_ENDPOINT="http://medusa-minio:9004/"
DC_MINIO_ROOT_USER=minioadmin
DC_MINIO_ROOT_PASSWORD=minioadmin
DC_MINIO_ACCESS_KEY=medusaappkey
DC_MINIO_SECRET_KEY=medusaappsecret_change_me

# Postgres container + bootstrap role setup
DC_POSTGRES_SUPERUSER=root
DC_POSTGRES_SUPERUSER_PASSWORD=root
DC_POSTGRES_PUBLIC_PORT=5432
DC_POSTGRES_SSLMODE=disable
DC_POSTGRES_VOLUME_DATA=./.docker_data/db18
# Bootstrap-only role used by init script (not used by medusa-be runtime directly)
DC_MEDUSA_DEV_DB_USER=medusa_dev
DC_MEDUSA_DEV_DB_PASSWORD=medusa_dev_change_me

# Meilisearch container
DC_MEILISEARCH_MASTER_KEY=MEILISEARCH_MASTER_KEY_FOR_DEVELOPMENT_ONLY

# Payload CMS bridge
DC_FEATURE_PAYLOAD_ENABLED=1
DC_PAYLOAD_API_KEY=payload_dev_api_key_change_me
DC_PAYLOAD_BASE_URL=http://localhost:8083
DC_PAYLOAD_IFRAME_URL=http://localhost:8083
DC_IS_IFRAME_PAYLOAD=true
DC_PAYLOAD_WEBHOOK_SECRET=payload_webhook_secret_change_me
DC_CMS_CACHE_TTL=3600
DC_CMS_LIST_CACHE_TTL=600
DC_PAYLOAD_SSO_ALG=RS256
DC_PAYLOAD_SSO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:9000,http://127.0.0.1:9000,https://admin.medusa.localhost
DC_PAYLOAD_SSO_AUDIENCE=payload
DC_PAYLOAD_SSO_ISSUER=medusa
DC_PAYLOAD_SSO_PRIVATE_KEY=
DC_PAYLOAD_SSO_PUBLIC_KEY=
DC_PAYLOAD_SSO_TOKEN_TTL=60
DC_PAYLOAD_SSO_USER_EMAIL=admin@example.com

# Payload CMS app
DC_FE_MEDUSA_BACKEND_URL=http://medusa-be:9000
DC_PAYLOAD_DATABASE_USER=payload
DC_PAYLOAD_DATABASE_PASSWORD=payload
DC_PAYLOAD_DATABASE_SCHEMA_NAME=payload
DC_PAYLOAD_DATABASE_URL="postgresql://${DC_PAYLOAD_DATABASE_USER}:${DC_PAYLOAD_DATABASE_PASSWORD}@medusa-db:5432/${DC_MEDUSA_APP_DB_NAME}?sslmode=disable&options=-csearch_path%3D${DC_PAYLOAD_DATABASE_SCHEMA_NAME}%2Cpg_catalog"
DC_PAYLOAD_SECRET=payload_secret_change_me
DC_PAYLOAD_LOCALES=cs,sk,en
DC_FEATURE_PAYLOAD_ARTICLES_ENABLED=1
DC_FEATURE_PAYLOAD_PAGES_ENABLED=1
DC_FEATURE_PAYLOAD_HERO_CAROUSELS_ENABLED=1
DC_PAYLOAD_S3_ENDPOINT=http://medusa-minio:9004
DC_PAYLOAD_S3_REGION=us-east-1
DC_PAYLOAD_S3_BUCKET=medusa-bucket
DC_PAYLOAD_S3_ACCESS_KEY_ID=minioadmin
DC_PAYLOAD_S3_SECRET_ACCESS_KEY=minioadmin
DC_OPENAI_API_KEY=

# zane-operator runtime and medusa-db bootstrap contract
DC_ZANE_OPERATOR_PUBLIC_PORT=8082
DC_ZANE_OPERATOR_PORT=8080
DC_ZANE_OPERATOR_API_AUTH_TOKEN=
DC_ZANE_OPERATOR_PGUSER=zane_operator
DC_ZANE_OPERATOR_PGPASSWORD=
DC_ZANE_OPERATOR_DB_PREVIEW_APP_PASSWORD_SECRET=
DC_ZANE_OPERATOR_PGDATABASE=postgres
DC_ZANE_OPERATOR_DB_TEMPLATE_NAME=template_medusa
DC_ZANE_OPERATOR_DB_PREVIEW_PREFIX=medusa_pr_
DC_ZANE_OPERATOR_DB_PREVIEW_APP_USER_PREFIX=medusa_pr_app_
DC_ZANE_OPERATOR_DB_PROTECTED_NAMES=postgres,template0,template1
DC_ZANE_OPERATOR_ZANE_BASE_URL=
DC_ZANE_OPERATOR_ZANE_CONNECT_BASE_URL=
DC_ZANE_OPERATOR_ZANE_CONNECT_HOST_HEADER=
DC_ZANE_OPERATOR_ZANE_USERNAME=
DC_ZANE_OPERATOR_ZANE_PASSWORD=
