{
  "name": "@nmit/payload",
  "version": "1.0.0",
  "description": "Payload 3.86.0 app",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --turbopack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "import:articles": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/import-articles.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/translations": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@pigment/auto-translate": "^1.5.0",
    "dotenv": "16.4.7",
    "exceljs": "^4.4.0",
    "graphql": "^16.8.1",
    "jose": "^5.9.6",
    "next": "16.3.0-preview.5",
    "payload": "3.86.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@playwright/test": "1.56.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "catalog:vite8-testing",
    "cross-env": "^7.0.3",
    "esbuild": "0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.3.0-preview.5",
    "jsdom": "26.1.0",
    "prettier": "^3.4.2",
    "typescript": "5.7.3",
    "vite": "catalog:vite8-testing",
    "vitest": "catalog:vite8-testing"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "^10 || ^11"
  }
}
