DATABASE_URL=postgresql://payload:payload@127.0.0.1:5432/payload
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Optional Postgres schema override. Leave unset to use the adapter default.
# PAYLOAD_SCHEMA_NAME=payload

FEATURE_PAYLOAD_ARTICLES_ENABLED=1
FEATURE_PAYLOAD_HERO_CAROUSELS_ENABLED=1
FEATURE_PAYLOAD_PAGES_ENABLED=1

PAYLOAD_LOCALES=cs,en,sk,pl,hu,ro,sl

# S3-compatible media storage (MinIO, AWS S3, etc.)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=payload-media
S3_ACCESS_KEY_ID=payload
S3_SECRET_ACCESS_KEY=payload-secret

# Auto-translate plugin (OpenAI)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
