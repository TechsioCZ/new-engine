{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "admin",
  "projectType": "application",
  "sourceRoot": "apps/admin/src",
  "tags": ["type:app", "platform:web", "framework:vite"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin",
        "command": "pnpm dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin",
        "command": "pnpm build"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin",
        "command": "pnpm typecheck"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin",
        "command": "pnpm test"
      }
    }
  }
}
