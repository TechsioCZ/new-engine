{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "medusa-symmy-plugin",
  "projectType": "library",
  "sourceRoot": "apps/medusa-symmy-plugin/src",
  "tags": ["type:lib", "platform:backend", "framework:medusa"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["production", "^production", "workspaceTooling"],
      "outputs": ["{projectRoot}/.medusa/server"],
      "options": {
        "command": "pnpm --dir apps/medusa-symmy-plugin build"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "workspaceTooling"],
      "outputs": [],
      "options": {
        "command": "pnpm --dir apps/medusa-symmy-plugin typecheck"
      }
    }
  }
}
