{
  "name": "medusa-symmy-plugin",
  "version": "0.1.0",
  "description": "Medusa v2 plugin that exposes an admin batch upsert endpoint for products with per-item identifier matching (sku/ean/erp_id) and partial-success semantics.",
  "keywords": [
    "batch",
    "import",
    "medusa-plugin",
    "medusa-v2",
    "products",
    "upsert"
  ],
  "license": "MIT",
  "author": "Tomáš Zbedina",
  "files": [
    ".medusa/server",
    "README.md"
  ],
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./.medusa/server/src/index.js",
      "require": "./.medusa/server/src/index.js",
      "types": "./.medusa/server/src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "pnpm lint:oxlint && pnpm lint:medusa",
    "lint:fix": "pnpm -w exec ultracite fix apps/medusa-symmy-plugin && pnpm lint:medusa",
    "lint:medusa": "eslint . --config eslint.config.ts --quiet",
    "prepare": "pnpm build",
    "publish:local": "medusa plugin:publish",
    "typecheck": "pnpm -w exec tsc --noEmit -p scripts/typescript/projects/apps/medusa-symmy-plugin/tsconfig.json",
    "lint:oxlint": "pnpm -w exec oxlint apps/medusa-symmy-plugin --type-aware --deny-warnings",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.17.2",
    "@medusajs/admin-shared": "^2.17.2",
    "@medusajs/cli": "^2.17.2",
    "@medusajs/framework": "^2.17.2",
    "@medusajs/icons": "^2.17.2",
    "@medusajs/medusa": "^2.17.2",
    "@medusajs/test-utils": "^2.17.2",
    "@medusajs/ui": "^4.1.19",
    "@swc/core": "1.15.3",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "express": "4.22.2",
    "mysql2": "^3.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.13.0",
    "@medusajs/medusa": "^2.13.0"
  },
  "engines": {
    "node": "24.x"
  }
}
