{
  "name": "medusa-symmy-plugin",
  "version": "0.1.0",
  "description": "Medusa v2 plugin that exposes an admin batch upsert endpoint for products with per-item identifier matching (sku/ean/erp_id) and partial-success semantics.",
  "author": "Tomáš Zbedina",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "medusa-plugin",
    "medusa-v2",
    "products",
    "batch",
    "upsert",
    "import"
  ],
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "files": [
    ".medusa/server",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./.medusa/server/src/index.js",
      "require": "./.medusa/server/src/index.js",
      "types": "./.medusa/server/src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "pnpm lint:biome && pnpm lint:medusa",
    "lint:biome": "pnpm -w exec biome check apps/medusa-symmy-plugin",
    "lint:fix": "pnpm -w exec biome check --write apps/medusa-symmy-plugin && pnpm lint:medusa",
    "lint:medusa": "medusa lint --quiet",
    "prepare": "pnpm build",
    "publish:local": "medusa plugin:publish",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.16.0",
    "@medusajs/admin-shared": "^2.16.0",
    "@medusajs/cli": "^2.16.0",
    "@medusajs/core-flows": "^2.16.0",
    "@medusajs/framework": "^2.16.0",
    "@medusajs/icons": "^2.16.0",
    "@medusajs/medusa": "^2.16.0",
    "@medusajs/test-utils": "^2.16.0",
    "@medusajs/ui": "^4.1.16",
    "@types/node": "^24.12.4",
    "@types/react": "^19.0.0",
    "mysql2": "^3.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.13.0",
    "@medusajs/medusa": "^2.13.0"
  }
}
