# Database config for @medusajs/test-utils (moduleIntegrationTestRunner)
NODE_ENV=test
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=root
DB_TEMP_NAME=medusa_test

REDIS_SESSIONS_ENABLED=0

# Integration tests must not use dev/live infrastructure providers.
NOTIFICATION_PROVIDER=local
MEILISEARCH_ENABLED=0
CACHE_PROVIDER=inmemory
EVENT_BUS_PROVIDER=local
WORKFLOW_ENGINE_PROVIDER=inmemory
LOCKING_PROVIDER=postgres
FILE_PROVIDER=local
FILE_LOCAL_UPLOAD_DIR=/tmp/medusa-be-test-files

# Auth secrets - deterministic test-only values.
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Settings Encryption (test key - 64 hex chars)
SETTINGS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CMS content cache TTL in seconds (default 3600)
CMS_CACHE_TTL=3600
# CMS list cache TTL in seconds (default 600)
CMS_LIST_CACHE_TTL=600
