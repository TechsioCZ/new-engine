{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "medusa-be",
  "projectType": "application",
  "sourceRoot": "apps/medusa-be/src",
  "tags": ["type:app", "platform:backend", "framework:medusa"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production", "workspaceTooling"],
      "outputs": [],
      "options": {
        "cwd": "apps/medusa-be",
        "command": "cross-env TEST_TYPE=unit node ./scripts/run-vitest.mjs run --config vitest.config.ts"
      }
    },
    "test-e2e-admin": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/medusa-be",
        "command": "pnpm test:e2e:admin"
      }
    },
    "test-e2e-admin-built": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/medusa-be",
        "command": "pnpm test:e2e:admin:built"
      }
    }
  }
}
