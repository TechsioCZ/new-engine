{
  "name": "medusa-be",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "keywords": [
    "ecommerce",
    "headless",
    "medusa",
    "postgres",
    "sqlite",
    "typescript"
  ],
  "license": "MIT",
  "author": "Medusa (https://medusajs.com)",
  "scripts": {
    "build": "node ./scripts/run-medusa.mjs build",
    "build:admin-smoke-output": "bash -euo pipefail -c 'MEDUSA_ADMIN_DISABLED_FOR_BACKEND_BUILD=1 pnpm build && pnpm exec medusa build --admin-only && rm -rf .medusa/server/public/admin && mkdir -p .medusa/server/public && cp -R .medusa/admin .medusa/server/public/admin'",
    "start": "medusa start",
    "entrypoint": "bash -euo pipefail -c 'npm run createInitialSuperadmin; : \"setInitialPublishableKey runs for side-effects only; setInitialPublishableKeyZerops persists the token\"; if [ \"${EXPOSE_INITIAL_PUBLISHABLE_KEY:-0}\" = \"1\" ]; then npm run -s setInitialPublishableKey; else npm run -s setInitialPublishableKey > /dev/null; fi'",
    "start:dev": "cross-env NODE_ENV=development medusa start",
    "start:ci-dev": "bash -euo pipefail -c 'npm run migrateProd && npm run entrypoint && exec npm run start:dev'",
    "develop": "medusa develop",
    "dev": "medusa develop",
    "lint": "pnpm lint:oxlint && pnpm lint:medusa",
    "lint:fix": "pnpm -w exec ultracite fix apps/medusa-be && pnpm lint:medusa",
    "lint:medusa": "eslint . --config eslint.config.ts --quiet",
    "test:integration:http": "cross-env TEST_TYPE=integration:http node ./scripts/run-vitest.mjs run --config vitest.config.ts",
    "test:integration:modules": "node ./scripts/run-module-tests.mjs",
    "test:e2e:http": "cross-env TEST_TYPE=e2e:http node ./scripts/run-vitest.mjs run --config vitest.config.ts",
    "test:e2e:db:create": "pg-god db-create",
    "test:e2e:db:drop": "pg-god db-drop",
    "test:e2e:http:debug": "cross-env TEST_TYPE=e2e:http node ./scripts/run-vitest.mjs --config vitest.config.ts --inspect-brk",
    "test:e2e:admin": "pnpm exec playwright test --config playwright.admin.config.ts",
    "test:e2e:admin:built": "cross-env MEDUSA_ADMIN_E2E_USE_BUILT_ADMIN=1 MEDUSA_ADMIN_E2E_SKIP_AUTH=1 pnpm exec playwright test --config playwright.admin.config.ts -g \"renders the Medusa admin login\"",
    "test:e2e:admin:install-browsers": "pnpm exec playwright install chromium",
    "test:unit": "cross-env TEST_TYPE=unit node ./scripts/run-vitest.mjs run --config vitest.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration:modules && pnpm test:integration:http",
    "migrateProd": "medusa db:migrate --execute-all-links",
    "migrate": "medusa db:migrate",
    "migrate:generate-only": "medusa db:generate",
    "syncLinks": "medusa db:sync-links",
    "createInitialSuperadmin": "bash -euo pipefail -c 'if [ -f ./src/scripts/create-initial-superadmin.ts ]; then medusa exec ./src/scripts/create-initial-superadmin.ts; else medusa exec ./src/scripts/create-initial-superadmin.js; fi'",
    "seedDevData": "medusa exec ./src/scripts/seed-dev-data.ts",
    "seedN1": "medusa exec ./src/scripts/seed-n1.ts",
    "seedPaykit": "medusa exec ./src/scripts/seed-paykit.ts",
    "seedQrPayment": "medusa exec ./src/scripts/seed-qr-payment.ts",
    "seedOrderBusinessStatusDemo": "medusa exec ./src/scripts/seed-order-business-status-demo.ts",
    "seedInitialData": "medusa exec ./src/scripts/seed.ts",
    "seedInitialDataTs": "medusa exec ./src/scripts/seed.ts",
    "seedDefaultData": "medusa exec ./src/scripts/seed-products-from-db.ts",
    "seedDefaultDataTs": "medusa exec ./src/scripts/seed-products-from-db.ts",
    "addInitialSearchDocuments": "medusa exec ./src/scripts/search-index.ts",
    "setInitialPublishableKey": "bash -euo pipefail -c 'PUBLISHABLE_KEY_TITLE=\"${INITIAL_PUBLISHABLE_KEY_NAME:-Storefront Publishable Key}\"; if [ -f ./src/scripts/output-publishable-key.ts ]; then medusa exec ./src/scripts/output-publishable-key.ts \"$PUBLISHABLE_KEY_TITLE\"; else medusa exec ./src/scripts/output-publishable-key.js \"$PUBLISHABLE_KEY_TITLE\"; fi | grep -o \"<PK_TOKEN>.*</PK_TOKEN>\" | sed \"s/<PK_TOKEN>//g;s/<\\\\/PK_TOKEN>//g\" | tr -d \"\\n\\r\"'",
    "setInitialPublishableKeyZerops": "bash -euo pipefail -c \"npm run -s setInitialPublishableKey | tr -d '\\n\\r' | zsc setSecretEnv CHANNEL_PUBLISHABLE_KEY\"",
    "seedHerbatica": "medusa exec ./src/scripts/herbatica-seed.ts",
    "seedHerbaticaReviews": "medusa exec ./src/scripts/herbatica-reviews-seed.ts",
    "cleanupHerbaticaLegacyCategories": "medusa exec ./src/scripts/herbatica-cleanup-legacy-categories.ts",
    "auditXmlVsDb": "medusa exec ./src/scripts/audit-xml-vs-db.ts",
    "debugProductCount": "medusa exec ./src/scripts/debug-product-count.ts",
    "typecheck": "pnpm -w exec tsc --noEmit -p scripts/typescript/projects/apps/medusa-be/tsconfig.json",
    "lint:oxlint": "pnpm -w exec oxlint apps/medusa-be --type-aware --deny-warnings"
  },
  "dependencies": {
    "@badgateway/oauth2-client": "^3.3.1",
    "@hookform/resolvers": "^5.4.0",
    "@mdxeditor/editor": "4.0.4",
    "@medusajs/admin-sdk": "^2.17.2",
    "@medusajs/admin-shared": "^2.17.2",
    "@medusajs/caching-redis": "^2.17.2",
    "@medusajs/cli": "^2.17.2",
    "@medusajs/dashboard": "^2.17.2",
    "@medusajs/draft-order": "^2.17.2",
    "@medusajs/event-bus-redis": "^2.17.2",
    "@medusajs/framework": "^2.17.2",
    "@medusajs/icons": "^2.17.2",
    "@medusajs/index": "^2.17.2",
    "@medusajs/js-sdk": "^2.17.2",
    "@medusajs/medusa": "^2.17.2",
    "@medusajs/modules-sdk": "^2.17.2",
    "@medusajs/types": "^2.17.2",
    "@medusajs/ui": "^4.1.19",
    "@medusajs/utils": "^2.17.2",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/core": "^2.4.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@paykit-sdk/comgate": "^1.3.2",
    "@paykit-sdk/core": "^1.3.3",
    "@paykit-sdk/gopay": "^1.3.2",
    "@paykit-sdk/stripe": "^1.3.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-radio-group": "1.4.3",
    "@radix-ui/react-slot": "1.3.0",
    "@rokmohar/medusa-plugin-meilisearch": "^1.4.3",
    "@sentry/node": "^10.66.0",
    "@sentry/opentelemetry": "^10.66.0",
    "@tanstack/react-query": "5.64.2",
    "@tanstack/react-table": "^8.21.3",
    "@techsio/std": "workspace:*",
    "@uiw/react-json-view": "2.0.0-alpha.43",
    "awilix": "8.0.1",
    "bwip-js": "^4.11.2",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "escape-html": "^1.0.3",
    "fast-xml-parser": "^5.10.1",
    "i18next": "26.3.6",
    "jose": "^6.2.3",
    "lodash": "^4.18.1",
    "marked": "18.0.6",
    "medusa-order-dashboard-plugin": "workspace:*",
    "medusa-plugin-content": "0.2.5",
    "medusa-symmy-plugin": "workspace:*",
    "mime": "4.1.0",
    "mysql2": "^3.23.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qs": "^6.15.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "17.0.10",
    "react-router-dom": "6.30.4",
    "resend": "^6.17.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@medusajs/promotion": "^2.17.2",
    "@medusajs/test-utils": "^2.17.2",
    "@swc/core": "^1.15.43",
    "@types/escape-html": "^1.0.4",
    "@types/node": "24.12.4",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/typescript-estree": "^8.64.0",
    "express": "4.22.2",
    "pg-god": "1.0.12",
    "scrypt-kdf": "^4.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "yalc": "1.0.0-pre.53"
  },
  "engines": {
    "node": "24.x"
  }
}
