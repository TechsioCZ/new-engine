{
  "name": "medusa-be",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "node ./scripts/run-medusa.mjs build",
    "start": "medusa start",
    "entrypoint": "bash -euo pipefail -c 'npm run createInitialSuperadmin; : \"setInitialPublishableKey runs for side-effects only; setInitialPublishableKeyZerops persists the token\"; if [ \"${EXPOSE_INITIAL_PUBLISHABLE_KEY:-0}\" = \"1\" ]; then npm run -s setInitialPublishableKey; else npm run -s setInitialPublishableKey > /dev/null; fi'",
    "start:dev": "cross-env NODE_ENV=development medusa start",
    "start:ci-dev": "bash -euo pipefail -c 'npm run migrateProd && npm run entrypoint && exec npm run start:dev'",
    "develop": "medusa develop",
    "dev": "medusa develop",
    "test:integration:http": "cross-env TEST_TYPE=integration:http node ./scripts/run-vitest.mjs run --config vitest.config.ts",
    "test:integration:modules": "node ./scripts/run-module-tests.mjs",
    "test:e2e:http": "cross-env TEST_TYPE=integration:http node ./scripts/run-vitest.mjs run --config vitest.config.ts integration-tests/http/*.spec.ts",
    "test:e2e:http:debug": "cross-env TEST_TYPE=integration:http node ./scripts/run-vitest.mjs --config vitest.config.ts integration-tests/http/*.spec.ts --inspect-brk",
    "test:unit": "cross-env TEST_TYPE=unit node ./scripts/run-vitest.mjs run --config vitest.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration:modules && pnpm test:integration:http",
    "migrateProd": "medusa db:migrate --execute-all-links",
    "migrate": "medusa db:migrate",
    "migrate:generate-only": "medusa db:generate",
    "syncLinks": "medusa db:sync-links",
    "createInitialSuperadmin": "bash -euo pipefail -c 'if [ -f ./src/scripts/create-initial-superadmin.ts ]; then medusa exec ./src/scripts/create-initial-superadmin.ts; else medusa exec ./src/scripts/create-initial-superadmin.js; fi'",
    "seedDevData": "medusa exec ./src/scripts/seed-dev-data.ts",
    "seedN1": "medusa exec ./src/scripts/seed-n1.ts",
    "seedOrderBusinessStatusDemo": "medusa exec ./src/scripts/seed-order-business-status-demo.ts",
    "seedInitialData": "medusa exec ./src/scripts/seed.ts",
    "seedInitialDataTs": "medusa exec ./src/scripts/seed.ts",
    "seedDefaultData": "medusa exec ./src/scripts/seed-products-from-db.ts",
    "seedDefaultDataTs": "medusa exec ./src/scripts/seed-products-from-db.ts",
    "addInitialSearchDocuments": "medusa exec ./src/scripts/search-index.ts",
    "setInitialPublishableKey": "bash -euo pipefail -c 'PUBLISHABLE_KEY_TITLE=\"${INITIAL_PUBLISHABLE_KEY_NAME:-Storefront Publishable Key}\"; if [ -f ./src/scripts/output-publishable-key.ts ]; then medusa exec ./src/scripts/output-publishable-key.ts \"$PUBLISHABLE_KEY_TITLE\"; else medusa exec ./src/scripts/output-publishable-key.js \"$PUBLISHABLE_KEY_TITLE\"; fi | grep -o \"<PK_TOKEN>.*</PK_TOKEN>\" | sed \"s/<PK_TOKEN>//g;s/<\\\\/PK_TOKEN>//g\" | tr -d \"\\n\\r\"'",
    "setInitialPublishableKeyZerops": "bash -euo pipefail -c \"npm run -s setInitialPublishableKey | tr -d '\\n\\r' | zsc setSecretEnv CHANNEL_PUBLISHABLE_KEY\"",
    "seedHerbatica": "medusa exec ./src/scripts/herbatica-seed.ts",
    "cleanupHerbaticaLegacyCategories": "medusa exec ./src/scripts/herbatica-cleanup-legacy-categories.ts",
    "auditXmlVsDb": "medusa exec ./src/scripts/audit-xml-vs-db.ts",
    "debugProductCount": "medusa exec ./src/scripts/debug-product-count.ts"
  },
  "dependencies": {
    "@badgateway/oauth2-client": "^3.3.1",
    "@mdxeditor/editor": "3.54.0",
    "@medusajs/admin-sdk": "^2.14.1",
    "@medusajs/admin-shared": "^2.14.1",
    "@medusajs/caching-redis": "^2.14.1",
    "@medusajs/cli": "^2.14.1",
    "@medusajs/dashboard": "^2.14.1",
    "@medusajs/draft-order": "^2.14.1",
    "@medusajs/event-bus-redis": "^2.14.1",
    "@medusajs/framework": "^2.14.1",
    "@medusajs/icons": "^2.14.1",
    "@medusajs/index": "^2.14.1",
    "@medusajs/js-sdk": "^2.14.1",
    "@medusajs/medusa": "^2.14.1",
    "@medusajs/ui": "^4.1.8",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.4.0",
    "@opentelemetry/core": "^2.4.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.210.0",
    "@opentelemetry/sdk-trace-base": "^2.4.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@rokmohar/medusa-plugin-meilisearch": "^1.3.5",
    "@sentry/node": "^10.29.0",
    "@sentry/opentelemetry": "^10.34.0",
    "@swc/helpers": "^0.5.18",
    "@tanstack/react-query": "5.64.2",
    "drizzle-orm": "^0.45.0",
    "escape-html": "^1.0.3",
    "fast-xml-parser": "^5.7.2",
    "i18next": "23.7.11",
    "jose": "^6.1.3",
    "marked": "15.0.12",
    "medusa-plugin-content": "0.2.0",
    "mime": "4.1.0",
    "mysql2": "^3.15.3",
    "pdf-lib": "^1.17.1",
    "qs": "^6.14.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-email": "6.0.8",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "resend": "^4.7.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "^2.14.1",
    "@swc/core": "^1.15.3",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^24.10.1",
    "@types/qs": "^6.9.17",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "yalc": "1.0.0-pre.53"
  },
  "engines": {
    "node": ">=24"
  }
}
