# Core runtime
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa
MEDUSA_DATABASE_SCHEMA=public
# Fallback schema env used by Medusa module DB loader.
DATABASE_SCHEMA=public
REDIS_URL=redis://localhost:6379

# Optional legacy MySQL source for migration scripts
LEGACY_DATABASE_URL=

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=MEILI_MASTER_KEY_FOR_DEVELOPMENT_ONLY

# File storage (S3/Minio)
MINIO_BUCKET=medusa-bucket
MINIO_ENDPOINT=http://localhost:9004
MINIO_FILE_URL=http://localhost:9004/medusa-bucket
MINIO_SECRET_KEY=supersecret
MINIO_ACCESS_KEY=supersecret
MINIO_REGION=us-east-1

# CORS and admin host
# Public storefront base URL (used to build links in transactional emails)
STOREFRONT_URL=http://localhost:3000
STORE_CORS=http://localhost:8000,http://localhost:9000,http://localhost
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000
MEDUSA_BACKEND_URL=localhost
NOTIFICATION_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=

# Auth secrets and bootstrap
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
INITIAL_PUBLISHABLE_KEY_NAME="Storefront Publishable Key"

# Observability
SENTRY_DSN=
SENTRY_NAME=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Settings encryption (sensitive module config stored in DB)
# Generate with: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# PPL Fulfillment Provider
# Set to "1" to enable PPL module, "0" to disable.
FEATURE_PPL_ENABLED=0
PPL_ENVIRONMENT=testing

# Payload CMS bridge
# Set to "1" to enable the Payload Medusa module.
FEATURE_PAYLOAD_ENABLED=0
PAYLOAD_BASE_URL=http://localhost:8083
PAYLOAD_IFRAME_URL=http://localhost:8083
PAYLOAD_API_KEY=
IS_IFRAME_PAYLOAD=true
PAYLOAD_WEBHOOK_SECRET=
CMS_CACHE_TTL=3600
CMS_LIST_CACHE_TTL=600

# Payload CMS Admin SSO
PAYLOAD_SSO_PRIVATE_KEY=
PAYLOAD_SSO_USER_EMAIL=
PAYLOAD_SSO_ISSUER=medusa
PAYLOAD_SSO_AUDIENCE=payload
PAYLOAD_SSO_ALG=RS256
PAYLOAD_SSO_TOKEN_TTL=60
