{
  "name": "medusa-order-dashboard-plugin",
  "version": "0.1.0",
  "description": "Internal Medusa v2 plugin that provides the unified order operations dashboard admin UI route.",
  "author": "Web Revolution",
  "license": "MIT",
  "keywords": [
    "medusa-plugin",
    "medusa-v2",
    "orders",
    "admin",
    "dashboard"
  ],
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "files": [
    ".medusa/server",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./.medusa/server/src/index.js",
      "require": "./.medusa/server/src/index.js",
      "types": "./.medusa/server/src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepare": "pnpm build",
    "publish:local": "medusa plugin:publish",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.15.2",
    "@medusajs/admin-shared": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/icons": "2.15.2",
    "@medusajs/js-sdk": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/ui": "4.1.12",
    "@tanstack/react-query": "5.64.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "mysql2": "3.15.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.13.0",
    "@medusajs/medusa": "^2.13.0"
  }
}
