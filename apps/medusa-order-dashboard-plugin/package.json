{
  "name": "medusa-order-dashboard-plugin",
  "version": "0.1.0",
  "description": "Internal Medusa v2 plugin that provides the unified order operations dashboard admin UI route.",
  "keywords": [
    "admin",
    "dashboard",
    "medusa-plugin",
    "medusa-v2",
    "orders"
  ],
  "license": "MIT",
  "author": "Web Revolution",
  "files": [
    ".medusa/server",
    "README.md"
  ],
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./.medusa/server/src/index.js",
      "require": "./.medusa/server/src/index.js",
      "types": "./.medusa/server/src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "pnpm lint:oxlint && pnpm lint:medusa",
    "lint:fix": "pnpm -w exec ultracite fix apps/medusa-order-dashboard-plugin && pnpm lint:medusa",
    "lint:medusa": "eslint . --config eslint.config.ts --quiet",
    "prepare": "pnpm build",
    "publish:local": "medusa plugin:publish",
    "typecheck": "pnpm -w exec tsc --noEmit -p scripts/typescript/projects/apps/medusa-order-dashboard-plugin/tsconfig.json",
    "lint:oxlint": "pnpm -w exec oxlint apps/medusa-order-dashboard-plugin --type-aware --deny-warnings"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/admin-shared": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/framework": "^2.17.2",
    "@medusajs/icons": "2.17.2",
    "@medusajs/js-sdk": "2.17.2",
    "@medusajs/medusa": "^2.17.2",
    "@medusajs/ui": "4.1.19",
    "@tanstack/react-query": "5.101.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "express": "4.22.2",
    "mysql2": "3.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.10",
    "react-router-dom": "7.18.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.13.0",
    "@medusajs/medusa": "^2.13.0"
  }
}
