{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@techsio/smart-suggest-client": [
        "../../libs/smart-suggest/client/src/client.ts"
      ],
      "@techsio/smart-suggest-core": [
        "../../libs/smart-suggest/core/src/core.ts"
      ],
      "@techsio/smart-suggest-react": [
        "../../libs/smart-suggest/react/src/react.ts"
      ],
      "@techsio/smart-suggest-ui": [
        "../../libs/smart-suggest/ui/src/address-suggest-field.tsx"
      ],
      "@techsio/smart-suggest-ui/*": ["../../libs/smart-suggest/ui/src/*"],
      "@techsio/smart-suggest-validation": [
        "../../libs/smart-suggest/validation/src/validation.ts"
      ],
      "@techsio/smart-suggest-validation/*": [
        "../../libs/smart-suggest/validation/src/*"
      ],
      "@techsio/storefront-data": ["../../libs/storefront-data/src/index.ts"],
      "@techsio/storefront-data/*": ["../../libs/storefront-data/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "local"]
}
