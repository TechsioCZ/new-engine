NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_with_sales_channel_linked_local_key
NEXT_PUBLIC_PAYLOAD_MEDIA_BASE_URL=http://localhost:8083
NEXT_PUBLIC_STOREFRONT_AUTH_MODE=session_proxy

# Local CMS editing:
# Payload admin is at http://localhost:8083/ and storefront CMS reads through
# local Medusa at http://localhost:9000/store/cms/...

# Compatibility alias when Payload media and API share the same public origin.
# Prefer NEXT_PUBLIC_PAYLOAD_MEDIA_BASE_URL for the local demo.
# NEXT_PUBLIC_PAYLOAD_BASE_URL=http://localhost:8083

# Optional pickup widgets.
NEXT_PUBLIC_PACKETA_WIDGET_API_KEY=
NEXT_PUBLIC_PACKETA_WIDGET_COUNTRIES=sk,cz
NEXT_PUBLIC_PPL_WIDGET_API_KEY=
