{
  "name": "frontend-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend demo application",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build --turbopack",
    "build:static": "next build --turbopack",
    "build:no-types": "cross-env SKIP_TYPE_CHECK=1 next build --turbopack",
    "start": "next start -p 3000",
    "check:unused": "node scripts/check-unused-exports.js",
    "generate:categories": "node scripts/generate-categories.mjs",
    "prebuild": "pnpm generate:categories",
    "typecheck": "pnpm -w exec tsc --noEmit -p scripts/typescript/projects/apps/frontend-demo/tsconfig.json"
  },
  "dependencies": {
    "@medusajs/js-sdk": "2.17.2",
    "@medusajs/types": "2.17.2",
    "@react-email/render": "2.1.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-store": "^0.11.0",
    "@techsio/ui-kit": "workspace:*",
    "dompurify": "^3.4.12",
    "next": "16.3.0-preview.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.500",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.19",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": "24.x"
  }
}
