{
  "schemaVersion": "smart-suggest-correctness-scenarios/v1",
  "id": "smart-suggest-production-correctness-proof-v1",
  "name": "Smart Suggest production correctness proof scenarios",
  "publicSafety": {
    "safeToCommit": true,
    "containsRawCustomerQueries": false,
    "containsPrivateProviderPayloads": false,
    "dataPolicy": "Public-safe authored benchmark prompts only. Scenario queries are deterministic fixture literals, not captured traffic."
  },
  "apiDefaults": {
    "pathPrefix": "/api/v1",
    "countryCode": "CZ",
    "language": "cs-CZ",
    "limit": 5
  },
  "benchmarkCorpus": {
    "path": "apps/smart-suggest/scripts/fixtures/smart-suggest-benchmark-corpus-v1.json",
    "schemaVersion": "smart-suggest-benchmark-corpus/v1"
  },
  "scenarios": [
    {
      "id": "correctness-address-full-k-louzi-diacritic",
      "description": "Full address with Czech diacritics must keep the canonical address as top result.",
      "endpoint": "suggest",
      "kind": "address",
      "benchmarkScenarioId": "addr-k-louzi-slash-diacritic-exact",
      "targetModes": ["local-benchmark", "http"],
      "query": "K Louži 1258/12, Praha 10",
      "labels": ["full-address", "diacritics", "cold-cache"],
      "request": {
        "countryCode": "CZ",
        "language": "cs-CZ",
        "limit": 5
      },
      "expected": {
        "topResultIds": ["ruian-cz:1203603"],
        "top5ResultIds": ["ruian-cz:1203603"],
        "requiredResultIds": ["ruian-cz:1203603"],
        "sourceIds": ["ruian-cz"],
        "resultCount": {
          "min": 1,
          "max": 5,
          "full": 1
        },
        "duplicateRate": {
          "max": 0
        },
        "providerEvents": {
          "maxTotal": 0
        },
        "cache": {
          "allowedStatuses": ["disabled", "miss", "written", "hit", "stale"]
        }
      }
    },
    {
      "id": "correctness-address-full-k-louzi-no-diacritic",
      "description": "Full address without diacritics must normalize to the same canonical address.",
      "endpoint": "suggest",
      "kind": "address",
      "benchmarkScenarioId": "addr-k-louzi-slash-no-diacritic",
      "targetModes": ["local-benchmark", "http"],
      "query": "K Louzi 1258/12 Praha 10",
      "labels": ["full-address", "no-diacritics"],
      "request": {
        "countryCode": "CZ",
        "language": "cs-CZ",
        "limit": 5
      },
      "expected": {
        "topResultIds": ["ruian-cz:1203603"],
        "top5ResultIds": ["ruian-cz:1203603"],
        "requiredResultIds": ["ruian-cz:1203603"],
        "sourceIds": ["ruian-cz"],
        "resultCount": {
          "min": 1,
          "max": 5,
          "full": 1
        },
        "duplicateRate": {
          "max": 0
        },
        "providerEvents": {
          "maxTotal": 0
        },
        "cache": {
          "allowedStatuses": ["disabled", "miss", "written", "hit", "stale"]
        }
      }
    },
    {
      "id": "correctness-street-fragment-k-louzi",
