    {
      "id": "correctness-zip-only-10100",
      "description": "ZIP-only postal suggest must cover every seeded locality for 10100 when production data is seeded.",
      "endpoint": "suggest",
      "kind": "postal",
      "targetModes": ["http"],
      "query": "10100",
      "labels": ["zip-only", "zip-locality-coverage", "requires-seeded-production-data"],
      "request": {
        "countryCode": "CZ",
        "language": "cs-CZ",
        "limit": 50
      },
      "expected": {
        "topResultIds": ["ruian-cz:postal:10100:praha-10"],
        "top5ResultIds": [
          "ruian-cz:postal:10100:praha-10",
          "ruian-cz:postal:10100:jina-obec",
          "ruian-cz:postal:10100:obec-25"
        ],
        "requiredResultIds": [
          "ruian-cz:postal:10100:praha-10",
          "ruian-cz:postal:10100:jina-obec",
          "ruian-cz:postal:10100:obec-25"
        ],
        "sourceIds": ["ruian-cz"],
        "resultCount": {
          "min": 3,
          "max": 50,
          "full": 27,
          "requiresSeededProductionData": true
        },
        "zipLocalityCoverage": {
          "postalCode": "10100",
          "fullResultCount": 27,
          "requiresSeededProductionData": true
        },
        "duplicateRate": {
          "max": 0
        },
        "providerEvents": {
          "maxTotal": 0
        },
        "cache": {
          "allowedStatuses": ["miss", "written", "hit", "stale"]
        }
      }
    },
    {
      "id": "correctness-zip-city-10100-praha",
