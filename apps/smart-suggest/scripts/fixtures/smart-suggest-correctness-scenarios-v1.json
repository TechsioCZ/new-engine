    {
      "id": "correctness-provider-timeout-owned-resilience",
      "description": "Provider timeout fixture label proves the runner can assert owned results survive provider timeout events when provider fixtures are configured.",
      "endpoint": "suggest",
      "kind": "address",
      "targetModes": ["http"],
      "query": "vaclavske",
      "labels": ["provider-timeout", "owned-resilience", "requires-provider-fixture"],
      "request": {
        "countryCode": "CZ",
        "language": "cs-CZ",
        "limit": 2,
        "tenantId": "tenant-provider-timeout-test"
      },
      "expected": {
        "topResultIds": ["ruian-cz:3300832"],
        "top5ResultIds": ["ruian-cz:3300832"],
        "requiredResultIds": ["ruian-cz:3300832"],
        "sourceIds": ["ruian-cz"],
        "resultCount": {
          "min": 1,
          "max": 2
        },
        "duplicateRate": {
          "max": 0
        },
        "providerEvents": {
          "allowedStatuses": ["timeout", "skipped", "success"],
          "requiresProviderFixture": true,
          "requiredStatusWhenFixtureEnabled": "timeout"
        },
        "cache": {
          "allowedStatuses": ["miss", "written", "hit", "stale"]
        }
      }
    },
    {
      "id": "correctness-validate-postal-cz",
      "description": "Postal validation endpoint must normalize a CZ ZIP without calling providers.",
      "endpoint": "validate-postal",
      "targetModes": ["http"],
      "labels": ["zip-only", "postal-validation"],
      "payload": {
        "countryCode": "CZ",
        "rawInput": "10100"
      },
      "expected": {
        "postalValidation": {
          "countryCode": "CZ",
          "displayValue": "101 00",
          "isValid": true,
          "normalizedValue": "10100"
        }
      }
    },
    {
      "id": "correctness-status-source-policy",
      "description": "Status endpoint must expose public operational health without raw-query storage.",
      "endpoint": "status",
      "targetModes": ["http"],
      "labels": ["status", "cold-cache"],
      "expected": {
        "status": {
          "service": "smart-suggest",
          "rawQueryStorage": "disabled"
        }
      }
    }
