{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "!{projectRoot}/dist/**",
      "!{projectRoot}/.medusa/**",
      "!{projectRoot}/.next/**",
      "!{projectRoot}/coverage/**",
      "!{projectRoot}/playwright-report/**",
      "!{projectRoot}/test-results/**",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.tsx",
      "!{projectRoot}/**/*.test.tsx",
      "!{projectRoot}/tests/**",
      "!{projectRoot}/integration-tests/**",
      "!{projectRoot}/e2e-tests/**",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/playwright*.config.ts"
    ],
    "workspaceTooling": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/tsconfig.json"
    ],
    "lintTooling": [
      "workspaceTooling",
      "{workspaceRoot}/biome.json",
      "{workspaceRoot}/eslint.config.ts",
      "{workspaceRoot}/eslint.nx.config.cjs"
    ],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"]
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json"
        }
      }
    }
  ],
  "targetDefaults": {
    "lint": {
      "cache": true,
      "inputs": ["default", "lintTooling"],
      "outputs": []
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production", "workspaceTooling"],
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production", "workspaceTooling"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"]
    },
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  }
}
